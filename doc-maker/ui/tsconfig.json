{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@source2video/framework-store": ["../../packages/framework-store/src/index"],
      "@source2video/framework-store/*": ["../../packages/framework-store/src/*"],
      "@source2video/workflow-core/*": ["../../packages/workflow-core/src/*"],
      "@source2video/observability/*": ["../../packages/observability/src/*"],
      "@doc-maker/writing-domain/*": ["../packages/writing-domain/src/*"],
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "../packages/**/*.ts", "../../packages/**/*.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
