{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@doc-maker/workflow-core/*": ["../packages/workflow-core/src/*"],
      "@doc-maker/observability/*": ["../packages/observability/src/*"],
      "@doc-maker/writing-domain/*": ["../packages/writing-domain/src/*"],
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "../packages/**/*.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
